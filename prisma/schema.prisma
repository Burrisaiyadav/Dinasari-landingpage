// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Application {
  id        Int      @id @default(autoincrement())
  jobTitle  String
  name      String
  email     String
  resume    String
  portfolio String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model Inquiry {
  id        Int      @id @default(autoincrement())
  type      String
  name      String
  email     String
  firm      String
  message   String?
  createdAt DateTime @default(now())
}

model Newsletter {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}
